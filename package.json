  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build",
    "build:local": "node migrate-pre-build.mjs && prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
